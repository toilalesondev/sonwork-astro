---
// `active` accepts more ids than the nav renders. The home/index page passes
// 'dashboard' and the /os-v1 + /gbrain routes pass their own id so they can be
// linked from elsewhere without lighting up a nav item — none of those three are
// listed in the nav itself (the brand logo links home). Nav = Writing · Projects · About.
interface Props {
  active: 'dashboard' | 'writing' | 'projects' | 'about' | 'gbrain';
}

const { active } = Astro.props;

import Logo from './Logo.astro';

const links: { href: string; label: string; id: Props['active'] }[] = [
  { href: '/series', label: 'Writing', id: 'writing' },
  { href: '/projects', label: 'Projects', id: 'projects' },
  { href: '/about', label: 'About', id: 'about' },
];
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="Sơn — home">
      <Logo size={24} class="nav-brand-mark" />
      <span class="nav-brand-wordmark">Sơn<span class="nav-dot">.</span></span>
    </a>
    <div class="nav-links">
      {links.map(link => (
        <a href={link.href} class:list={['nav-link', { active: link.id === active }]}>{link.label}</a>
      ))}
    </div>
  </div>
</nav>
