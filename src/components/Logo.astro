---
// Sonwork logo mark — a geometric "S" set in an OS app-tile.
// Monochrome via currentColor so it inverts cleanly.
interface Props {
  size?: number;
  class?: string;
}
const { size = 26, class: className } = Astro.props;
---
<svg
  class:list={[className]}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  role="img"
  aria-label="Sơn — home"
>
  <rect x="1.5" y="1.5" width="29" height="29" rx="7" stroke="currentColor" stroke-width="2" />
  <path
    d="M20.8 11.4C20.8 9.3 18.6 8.4 16 8.4C13.1 8.4 11 9.7 11 12.1C11 16.6 21 14.9 21 19.9C21 22.3 18.6 23.6 16 23.6C13.4 23.6 11.2 22.6 11.2 20.3"
    stroke="currentColor"
    stroke-width="2.7"
    stroke-linecap="round"
  />
</svg>
