---
// Sonwork logo mark — a geometric "S" set in an OS app-tile, with a terminal
// cursor block at the end of the stroke: the letter reads as if just typed at a
// command prompt. Monochrome via currentColor (the parent sets the color), so it
// inverts cleanly and works as a single flat color anywhere.
//
// `cursor` toggles the blinking caret block (on for the nav lockup, off for the
// favicon-style tiny render where the block would merge with the stroke).
interface Props {
  size?: number;
  cursor?: boolean;
  class?: string;
}
const { size = 26, cursor = true, class: className } = Astro.props;
---
<svg
  class:list={['logo-mark', className]}
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  role="img"
  aria-label="Sơn — home"
>
  <rect x="1.5" y="1.5" width="29" height="29" rx="7" stroke="currentColor" stroke-width="2" />
  <path
    d="M20.8 11.4C20.8 9.3 18.6 8.4 16 8.4C13.1 8.4 11 9.7 11 12.1C11 16.6 21 14.9 21 19.9C21 22.3 18.6 23.6 16 23.6C13.4 23.6 11.2 22.6 11.2 20.3"
    stroke="currentColor"
    stroke-width="2.7"
    stroke-linecap="round"
  />
  {cursor && (
    <rect class="logo-cursor" x="20.2" y="20.4" width="3" height="3.4" rx="0.5" fill="currentColor" />
  )}
</svg>

<style>
  .logo-mark { display: block; flex: none; }
  .logo-cursor {
    transform-box: fill-box;
    transform-origin: center;
    animation: logo-blink 1.2s steps(1, end) infinite;
  }
  @keyframes logo-blink {
    0%, 55% { opacity: 1; }
    56%, 92% { opacity: 0; }
    93%, 100% { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .logo-cursor { animation: none; opacity: 1; }
  }
</style>
