---
interface Props {
  title: string;
  description?: string;
}

const siteName = "Sơn";
const { title, description = "Personal writing by Sơn Lê." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title !== siteName ? `${title} — ${siteName}` : siteName}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <style>
      :root {
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --border: #e8e8e8;
        --max: 680px;
        --font: 'Georgia', 'Times New Roman', serif;
        --mono: 'SF Mono', 'Fira Code', monospace;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f0f0f;
          --fg: #e8e8e8;
          --muted: #888;
          --border: #2a2a2a;
        }
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 18px; }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font);
        line-height: 1.75;
        padding: 0 1.5rem;
        max-width: var(--max);
        margin: 0 auto;
        -webkit-font-smoothing: antialiased;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 2.5rem 0 2rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 3rem;
      }
      nav a.site-name {
        font-size: 1rem;
        font-weight: normal;
        color: var(--fg);
        text-decoration: none;
      }
      nav .nav-links { display: flex; gap: 1.5rem; }
      nav .nav-links a {
        font-size: 0.85rem;
        color: var(--muted);
        text-decoration: none;
        letter-spacing: 0.02em;
      }
      nav .nav-links a:hover { color: var(--fg); }

      main { min-height: 60vh; }

      footer {
        margin-top: 5rem;
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        font-size: 0.8rem;
        color: var(--muted);
      }

      h1 { font-size: 1.6rem; font-weight: normal; line-height: 1.3; margin-bottom: 0.5rem; }
      h2 { font-size: 1.2rem; font-weight: normal; margin: 2.5rem 0 1rem; }
      h3 { font-size: 1rem; font-weight: bold; margin: 2rem 0 0.75rem; }
      p { margin-bottom: 1.4rem; }

      a { color: var(--fg); }
      a:hover { opacity: 0.7; }

      blockquote {
        border-left: 3px solid var(--border);
        padding-left: 1.2rem;
        color: var(--muted);
        font-style: italic;
        margin: 1.5rem 0;
      }

      code {
        font-family: var(--mono);
        font-size: 0.82em;
        background: var(--border);
        padding: 0.1em 0.35em;
        border-radius: 3px;
      }

      pre {
        background: var(--border);
        padding: 1.2rem;
        border-radius: 6px;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      pre code { background: none; padding: 0; }

      img { max-width: 100%; height: auto; border-radius: 4px; margin: 1.5rem 0; }
      hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
      ul, ol { padding-left: 1.4rem; margin-bottom: 1.4rem; }
      li { margin-bottom: 0.3rem; }

      .post-list { list-style: none; padding: 0; }
      .post-list li {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--border);
      }
      .post-list li:first-child { border-top: 1px solid var(--border); }
      .post-list a { text-decoration: none; font-size: 1rem; }
      .post-list a:hover { opacity: 0.7; }
      .post-list .date { font-size: 0.8rem; color: var(--muted); white-space: nowrap; flex-shrink: 0; }

      .post-header { margin-bottom: 2.5rem; }
      .post-header h1 { margin-bottom: 0.75rem; }
      .post-meta { font-size: 0.82rem; color: var(--muted); }
      .post-meta .tags { margin-top: 0.4rem; }
      .post-meta .tag {
        display: inline-block;
        background: var(--border);
        padding: 0.1em 0.5em;
        border-radius: 3px;
        font-size: 0.75rem;
        margin-right: 0.3rem;
        color: var(--muted);
        text-decoration: none;
      }

      .post-body { font-size: 1rem; }
    </style>
  </head>
  <body>
    <nav>
      <a class="site-name" href="/">Sơn</a>
      <div class="nav-links">
        <a href="/">Writing</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      © {new Date().getFullYear()} Sơn Lê
    </footer>
  </body>
</html>
