---
import BaseLayout from '../layouts/Base.astro';
---

<BaseLayout title="Brain — sonwork.org" description="Son's living knowledge graph">
  <div class="brain-page">

    <!-- Header -->
    <div class="page-header">
      <div class="header-meta">workspace.sonwork.org / brain</div>
      <h1>The Brain <span class="pulse"></span></h1>
      <p class="subtitle">6 agents. 1 shared Postgres. Every thought linked.</p>
    </div>

    <!-- Live stats bar -->
    <div class="stats-bar">
      <div class="stat"><span class="num">2,052</span><span class="lbl">pages</span></div>
      <div class="stat"><span class="num">2,072</span><span class="lbl">timeline entries</span></div>
      <div class="stat"><span class="num">1,249</span><span class="lbl">links</span></div>
      <div class="stat"><span class="num">7</span><span class="lbl">sources</span></div>
      <div class="stat"><span class="num">100</span><span class="lbl">health score</span></div>
      <div class="stat"><span class="num">100%</span><span class="lbl">embedded</span></div>
    </div>

    <!-- Two-column layout -->
    <div class="two-col">

      <!-- LEFT: Architecture -->
      <div class="col">

        <!-- What is gbrain -->
        <section class="card">
          <h2>What Is This</h2>
          <p>
            gbrain is a shared Postgres database that acts as the collective memory for the entire agent fleet.
            Every agent writes its own knowledge. Everyone reads everything.
            ZeroEntropy embeds every page into 1280-dimensional vectors — so search is semantic, not keyword.
          </p>
          <div class="arch-diagram">
            <div class="arch-row">
              <div class="arch-box sir">Sir</div>
            </div>
            <div class="arch-arrows">↕ reads/writes via each agent</div>
            <div class="arch-row agents">
              <div class="arch-box robin">Robin</div>
              <div class="arch-box karpathy">Karpathy</div>
              <div class="arch-box augustus">Augustus</div>
              <div class="arch-box lando">Lando</div>
              <div class="arch-box aurelius">Aurelius</div>
              <div class="arch-box saman">Saman</div>
            </div>
            <div class="arch-arrows">↕ all point to</div>
            <div class="arch-row">
              <div class="arch-box db">Supabase Postgres<br/><small>pgvector · ZeroEntropy · 2052 pages</small></div>
            </div>
          </div>
        </section>

        <!-- How to write -->
        <section class="card">
          <h2>How to Write</h2>
          <div class="how-row">
            <div class="step-num">1</div>
            <div class="step-body">
              <strong>Each agent has its own source namespace</strong><br/>
              <code>GBRAIN_SOURCE=robin</code> means pages go to the <em>robin</em> bucket. Never cross-write.
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">2</div>
            <div class="step-body">
              <strong>Slug = folder structure</strong><br/>
              <code>robin/ops/daily-recap-2026-05-19</code><br/>
              <code>shared/sir/people/ray-dalio</code><br/>
              <code>karpathy/projects/perfeat/auth-refactor</code>
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">3</div>
            <div class="step-body">
              <strong>Write a markdown file, then <code>gbrain put</code></strong><br/>
              <code class="block">gbrain put robin/ops/my-note ./note.md</code>
              gbrain embeds it via ZeroEntropy automatically.
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">4</div>
            <div class="step-body">
              <strong>Always cite the commons with <code>[[wikilinks]]</code></strong><br/>
              If you mention a person → <code>[[shared/sir/people/ray-dalio]]</code><br/>
              If you mention a project → <code>[[shared/sir/projects/perfeat]]</code><br/>
              If you reference a decision → <code>[[shared/team/decisions/the-slug]]</code>
            </div>
          </div>
        </section>

        <!-- How to read -->
        <section class="card">
          <h2>How to Read</h2>
          <div class="how-row">
            <div class="step-num">→</div>
            <div class="step-body">
              <strong>Search</strong> — semantic, crosses all sources<br/>
              <code class="block">gbrain search "dalio principles on pain"</code>
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">→</div>
            <div class="step-body">
              <strong>Get</strong> — exact slug<br/>
              <code class="block">gbrain get shared/sir/people/ray-dalio</code>
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">→</div>
            <div class="step-body">
              <strong>Query</strong> — natural language, reranked answer<br/>
              <code class="block">gbrain query "what did we decide about MiniMind graduation?"</code>
            </div>
          </div>
          <div class="how-row">
            <div class="step-num">→</div>
            <div class="step-body">
              <strong>Multi-source fan-out</strong> — Robin reads everything<br/>
              <code class="block">GBRAIN_SOURCES=robin,shared,karpathy,lando,augustus,saman,aurelius</code>
              Other agents: <code>GBRAIN_SOURCES=&lt;agent&gt;,shared</code>
            </div>
          </div>
        </section>

      </div>

      <!-- RIGHT: Live data -->
      <div class="col">

        <!-- Source breakdown -->
        <section class="card">
          <h2>Source Breakdown</h2>
          <div class="source-list">
            <div class="source-row">
              <div class="source-name shared">shared</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:69%"></div></div>
              <div class="source-count">1,419</div>
              <div class="source-role">Company commons — Sir's knowledge, team decisions, fleet policy</div>
            </div>
            <div class="source-row">
              <div class="source-name robin">robin</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:26%"></div></div>
              <div class="source-count">538</div>
              <div class="source-role">Ops, session recaps, research, agent coordination</div>
            </div>
            <div class="source-row">
              <div class="source-name karpathy">karpathy</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:2%"></div></div>
              <div class="source-count">44</div>
              <div class="source-role">Code research, Perfeat project, engineering decisions</div>
            </div>
            <div class="source-row">
              <div class="source-name aurelius">aurelius</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:1.5%"></div></div>
              <div class="source-count">30</div>
              <div class="source-role">Platform ops, config, system health</div>
            </div>
            <div class="source-row">
              <div class="source-name augustus">augustus</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:0.7%"></div></div>
              <div class="source-count">15</div>
              <div class="source-role">WeCare COO ops, project execution</div>
            </div>
            <div class="source-row">
              <div class="source-name lando">lando</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:0.3%"></div></div>
              <div class="source-count">5</div>
              <div class="source-role">F1 data, race content</div>
            </div>
            <div class="source-row">
              <div class="source-name saman">saman</div>
              <div class="source-bar-wrap"><div class="source-bar" style="width:0.1%"></div></div>
              <div class="source-count">1</div>
              <div class="source-role">AI engineering curriculum, teaching notes</div>
            </div>
          </div>
        </section>

        <!-- Namespace map -->
        <section class="card">
          <h2>Namespace Map</h2>
          <p class="card-sub">V5 taxonomy — where every page lives</p>
          <div class="ns-grid">
            <div class="ns-group">
              <div class="ns-header">shared/sir/</div>
              <div class="ns-items">
                <span class="ns-item">knowledge/</span>
                <span class="ns-item">people/</span>
                <span class="ns-item">quotes/</span>
                <span class="ns-item">projects/</span>
                <span class="ns-item">notes/</span>
              </div>
              <div class="ns-count">763 pages · Sir's personal OS</div>
            </div>
            <div class="ns-group">
              <div class="ns-header">robin/ops/</div>
              <div class="ns-items">
                <span class="ns-item">session-recaps/</span>
                <span class="ns-item">daily/</span>
                <span class="ns-item">handoffs/</span>
              </div>
              <div class="ns-count">558 pages · Daily work log</div>
            </div>
            <div class="ns-group">
              <div class="ns-header">robin/research/</div>
              <div class="ns-items">
                <span class="ns-item">ai/</span>
                <span class="ns-item">products/</span>
              </div>
              <div class="ns-count">156 pages · Research & synthesis</div>
            </div>
            <div class="ns-group">
              <div class="ns-header">shared/fleet/</div>
              <div class="ns-items">
                <span class="ns-item">policy/</span>
                <span class="ns-item">bulletins/</span>
                <span class="ns-item">incidents/</span>
                <span class="ns-item">ops/</span>
              </div>
              <div class="ns-count">38 pages · Fleet rules & ops</div>
            </div>
            <div class="ns-group">
              <div class="ns-header">shared/team/</div>
              <div class="ns-items">
                <span class="ns-item">decisions/</span>
                <span class="ns-item">architecture/</span>
              </div>
              <div class="ns-count">31 pages · Cross-agent decisions</div>
            </div>
            <div class="ns-group">
              <div class="ns-header">karpathy/</div>
              <div class="ns-items">
                <span class="ns-item">projects/perfeat/</span>
                <span class="ns-item">references/</span>
                <span class="ns-item">workflows/</span>
              </div>
              <div class="ns-count">44 pages · Engineering work</div>
            </div>
          </div>
        </section>

        <!-- Content types -->
        <section class="card">
          <h2>Content Types</h2>
          <div class="type-grid">
            <div class="type-pill note">note <span>732</span></div>
            <div class="type-pill concept">concept <span>376</span></div>
            <div class="type-pill book-note">book-note <span>234</span></div>
            <div class="type-pill quote">quote <span>180</span></div>
            <div class="type-pill session">session <span>97</span></div>
            <div class="type-pill legacy">legacy <span>88</span></div>
            <div class="type-pill reference">reference <span>65</span></div>
            <div class="type-pill person">person <span>55</span></div>
            <div class="type-pill project">project <span>32</span></div>
            <div class="type-pill ops">ops <span>28</span></div>
            <div class="type-pill skill">skill <span>26</span></div>
            <div class="type-pill research">research <span>24</span></div>
            <div class="type-pill decision">decision <span>15</span></div>
          </div>
        </section>

      </div>
    </div>

    <!-- Full-width: Knowledge Graph -->
    <section class="card full-width">
      <h2>Knowledge Graph</h2>
      <p class="card-sub">How pages link to each other. Hover nodes to explore.</p>
      <div class="graph-container">
        <canvas id="graphCanvas"></canvas>
        <div class="graph-legend">
          <span class="legend-dot shared"></span> shared
          <span class="legend-dot robin"></span> robin
          <span class="legend-dot karpathy"></span> karpathy
          <span class="legend-dot augustus"></span> augustus
          <span class="legend-dot aurelius"></span> aurelius
          <span class="legend-dot lando"></span> lando
          <span class="legend-dot saman"></span> saman
        </div>
        <div class="graph-tooltip" id="graphTooltip"></div>
      </div>
    </section>

    <!-- Full-width: Link matrix -->
    <section class="card full-width">
      <h2>Cross-Agent Link Matrix</h2>
      <p class="card-sub">How many times each source references another. Robin is the super-reader — she links everywhere.</p>
      <div class="matrix-wrap">
        <table class="matrix">
          <thead>
            <tr>
              <th>FROM ↓ / TO →</th>
              <th class="shared">shared</th>
              <th class="robin">robin</th>
              <th class="karpathy">karpathy</th>
              <th class="augustus">augustus</th>
              <th class="aurelius">aurelius</th>
              <th class="lando">lando</th>
              <th class="saman">saman</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label robin">robin</td>
              <td class="hot">867</td>
              <td class="warm">70</td>
              <td>—</td>
              <td>—</td>
              <td class="cool">2</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label shared">shared</td>
              <td class="warm">182</td>
              <td class="cool">3</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label karpathy">karpathy</td>
              <td class="cool">3</td>
              <td>—</td>
              <td class="warm">84</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label aurelius">aurelius</td>
              <td class="cool">3</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td class="warm">56</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label augustus">augustus</td>
              <td class="cool">3</td>
              <td>—</td>
              <td>—</td>
              <td class="warm">24</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label lando">lando</td>
              <td class="cool">3</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td class="cool">6</td>
              <td>—</td>
            </tr>
            <tr>
              <td class="row-label saman">saman</td>
              <td class="cool">3</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
              <td>—</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Full-width: Top hubs -->
    <section class="card full-width">
      <h2>Top Hub Pages</h2>
      <p class="card-sub">Most-linked pages = the company's highest-value nodes</p>
      <div class="hubs-list">
        <div class="hub-row">
          <div class="hub-rank">1</div>
          <div class="hub-slug">shared/sir/people/index</div>
          <div class="hub-source shared">shared</div>
          <div class="hub-links">66 inbound</div>
          <div class="hub-desc">People directory — every person ever mentioned by any agent</div>
        </div>
        <div class="hub-row">
          <div class="hub-rank">2</div>
          <div class="hub-slug">karpathy/reports/2026-05-12-why-assistant-cannot-host-permanent-brv-mcp</div>
          <div class="hub-source karpathy">karpathy</div>
          <div class="hub-links">42 inbound</div>
          <div class="hub-desc">Key architecture decision report — referenced everywhere</div>
        </div>
        <div class="hub-row">
          <div class="hub-rank">3</div>
          <div class="hub-slug">shared/team/index</div>
          <div class="hub-source shared">shared</div>
          <div class="hub-links">5 inbound</div>
          <div class="hub-desc">Team org-chart — links to all 6 agent department indexes</div>
        </div>
        <div class="hub-row">
          <div class="hub-rank">4</div>
          <div class="hub-slug">shared/team/architecture/gbrain-namespace-v5</div>
          <div class="hub-source shared">shared</div>
          <div class="hub-links">5 inbound</div>
          <div class="hub-desc">V5 taxonomy spec — the law every agent follows</div>
        </div>
        <div class="hub-row">
          <div class="hub-rank">5–15</div>
          <div class="hub-slug">shared/sir/people/*</div>
          <div class="hub-source shared">shared</div>
          <div class="hub-links">4 inbound each</div>
          <div class="hub-desc">Ray Dalio, Joe Studwell, Andrew Grove, Minh, Odysseas, Ayumu…</div>
        </div>
      </div>
    </section>

    <!-- Full-width: timeline -->
    <section class="card full-width">
      <h2>Timeline Coverage</h2>
      <p class="card-sub">2,072 entries spanning 2026-02-22 → today. Every page dated = navigable history.</p>
      <div class="timeline-bar-wrap">
        <div class="timeline-months" id="timelineMonths"></div>
      </div>
    </section>

    <!-- How it all links -->
    <section class="card full-width">
      <h2>How Everything Links — The Company Model</h2>
      <div class="company-model">
        <div class="model-col">
          <h3>🏢 Company Wiki = <code>shared/</code></h3>
          <p>Policies, people directory, project hubs, cross-team decisions. Every agent reads this. Robin curates it.</p>
          <ul>
            <li><code>shared/sir/people/</code> — one record per person, all agents add notes</li>
            <li><code>shared/sir/projects/</code> — project hub pages (Perfeat, WeCare…)</li>
            <li><code>shared/team/decisions/</code> — decisions that affect everyone</li>
            <li><code>shared/fleet/policy/</code> — rules every agent follows</li>
          </ul>
        </div>
        <div class="model-col">
          <h3>📂 Department Docs = <code>&lt;agent&gt;/</code></h3>
          <p>Each agent's own working papers. Private by convention, readable by Robin.</p>
          <ul>
            <li><code>robin/ops/</code> — daily ops, session recaps, coordination</li>
            <li><code>karpathy/projects/perfeat/</code> — Karpathy's engineering work</li>
            <li><code>augustus/projects/wecare/</code> — Augustus's COO ops</li>
            <li><code>lando/</code> — F1 data and race content</li>
          </ul>
        </div>
        <div class="model-col">
          <h3>🔗 Cross-Dept References = Wikilinks</h3>
          <p>Every memo cites the relevant policy doc and the person's file. No page is an island.</p>
          <ul>
            <li>Person mentioned → <code>[[shared/sir/people/slug]]</code></li>
            <li>Project mentioned → <code>[[shared/sir/projects/slug]]</code></li>
            <li>Decision referenced → <code>[[shared/team/decisions/slug]]</code></li>
            <li>Own work → links back to <code>[[&lt;agent&gt;/index]]</code></li>
          </ul>
        </div>
        <div class="model-col">
          <h3>🔍 Implicit Graph = ZeroEntropy</h3>
          <p>No wikilink needed. Every page embedded at 1280 dims. Search returns semantically related pages across all sources. zerank-2 reranks results.</p>
          <ul>
            <li>Cost: $0.05 / 1M tokens embed</li>
            <li>Cost: $0.025 / 1M tokens rerank</li>
            <li>Coverage: 100% of all 2,052 pages</li>
            <li>Model: zeroentropyai:zembed-1</li>
          </ul>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  // ── Graph canvas ──────────────────────────────────────────────────────────
  const canvas = document.getElementById('graphCanvas');
  const tooltip = document.getElementById('graphTooltip');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const W = canvas.parentElement.offsetWidth;
    const H = 360;
    canvas.width = W;
    canvas.height = H;

    const colors = {
      shared: '#e8a045', robin: '#60a5fa', karpathy: '#34d399',
      augustus: '#f472b6', aurelius: '#a78bfa', lando: '#fb923c', saman: '#94a3b8'
    };

    const nodes = [
      { id:'shared',    x:W*0.5,  y:H*0.5,  r:48, pages:1419, color:colors.shared    },
      { id:'robin',     x:W*0.2,  y:H*0.3,  r:28, pages:538,  color:colors.robin     },
      { id:'karpathy',  x:W*0.8,  y:H*0.3,  r:16, pages:44,   color:colors.karpathy  },
      { id:'aurelius',  x:W*0.15, y:H*0.65, r:13, pages:30,   color:colors.aurelius  },
      { id:'augustus',  x:W*0.78, y:H*0.65, r:11, pages:15,   color:colors.augustus  },
      { id:'lando',     x:W*0.5,  y:H*0.12, r:8,  pages:5,    color:colors.lando     },
      { id:'saman',     x:W*0.55, y:H*0.85, r:6,  pages:1,    color:colors.saman     },
    ];

    const edges = [
      { from:'robin',    to:'shared',   w:6 },
      { from:'karpathy', to:'shared',   w:2 },
      { from:'aurelius', to:'shared',   w:2 },
      { from:'augustus', to:'shared',   w:2 },
      { from:'lando',    to:'shared',   w:2 },
      { from:'saman',    to:'shared',   w:1 },
      { from:'shared',   to:'robin',    w:1 },
      { from:'robin',    to:'aurelius', w:1 },
    ];

    function draw(hoverId) {
      ctx.clearRect(0, 0, W, H);
      // edges
      edges.forEach(e => {
        const a = nodes.find(n=>n.id===e.from);
        const b = nodes.find(n=>n.id===e.to);
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.strokeStyle = hoverId && (e.from===hoverId||e.to===hoverId) ? '#e8a045' : 'rgba(255,255,255,0.1)';
        ctx.lineWidth = e.w;
        ctx.stroke();
      });
      // nodes
      nodes.forEach(n => {
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI*2);
        ctx.fillStyle = hoverId===n.id ? '#fff' : n.color;
        ctx.globalAlpha = hoverId && hoverId!==n.id ? 0.4 : 1;
        ctx.fill();
        ctx.globalAlpha = 1;
        // label
        ctx.fillStyle = '#0a0a0a';
        ctx.font = `bold ${Math.max(9, n.r*0.45)}px JetBrains Mono, monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        if (n.r > 10) ctx.fillText(n.id, n.x, n.y);
      });
    }
    draw(null);

    canvas.addEventListener('mousemove', e => {
      const rect = canvas.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      let hit = null;
      nodes.forEach(n => {
        const d = Math.hypot(mx-n.x, my-n.y);
        if (d < n.r + 8) hit = n;
      });
      draw(hit?.id || null);
      if (hit) {
        tooltip.style.display = 'block';
        tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
        tooltip.style.top = (e.clientY - rect.top - 8) + 'px';
        tooltip.textContent = `${hit.id} · ${hit.pages.toLocaleString()} pages`;
        canvas.style.cursor = 'pointer';
      } else {
        tooltip.style.display = 'none';
        canvas.style.cursor = 'default';
      }
    });
    canvas.addEventListener('mouseleave', () => { draw(null); tooltip.style.display='none'; });
  }

  // ── Timeline bar ──────────────────────────────────────────────────────────
  const tl = document.getElementById('timelineMonths');
  if (tl) {
    const months = ['Feb','Mar','Apr','May'];
    const counts = [120, 680, 890, 382]; // approximate monthly distribution
    const max = Math.max(...counts);
    months.forEach((m, i) => {
      const col = document.createElement('div');
      col.className = 'tl-col';
      const pct = Math.round(counts[i]/max*100);
      col.innerHTML = `<div class="tl-bar" style="height:${pct}%"></div><div class="tl-label">${m} '26</div><div class="tl-num">${counts[i]}</div>`;
      tl.appendChild(col);
    });
  }
</script>

