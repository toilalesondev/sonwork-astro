---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({data}) => !data.draft))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const seriesMap: Record<string, {name:string, marker:string, badgeClass:string, desc:string, tagline:string}> = {
  'life-book':   { name:'Life Book',   marker:'§',  badgeClass:'badge-life',  tagline:'One year at a time, until there are fifty.', desc:'Year-by-year entries written as they happen, compiled into a physical book at 50. Not memoir — evidence.' },
  'experiences': { name:'Experiences', marker:'↳', badgeClass:'badge-exp',   tagline:'Things I lived through, written before I rewrite them in my head.', desc:'Not advice. Not lessons. Accounts of specific situations that were real enough to leave a mark.' },
  'human':       { name:'Human',       marker:'◎', badgeClass:'badge-human', tagline:'Psychology without the jargon. People without the flattery.', desc:'How people think, decide, break, and convince themselves they didn\'t. More useful than most frameworks.' },
};
---
<Base title="Series — Sơn Lê">
  <nav class="nav">
    <a href="/" class="nav-brand">Sơn<span class="nav-dot">.</span></a>
    <div class="nav-links">
      <a href="/" class="nav-link">Dashboard</a>
      <a href="/series" class="nav-link active">Series</a>
      <a href="/contact" class="nav-link">Contact</a>
    </div>
  </nav>

  <div class="page-wrap">
    <div class="page-header">
      <div class="mono text-3 page-prompt">./series</div>
      <h1 class="page-title">Series</h1>
      <p class="page-sub">Long-form collections. Each one is a thread — posts that belong together.</p>
    </div>

    {Object.entries(seriesMap).map(([key, s]) => {
      const posts = allPosts.filter(p => p.data.series === key);
      return (
        <div class="series-section">
          <div class="series-section-hd">
            <span class={`series-marker-lg mono ${s.badgeClass}`}>{s.marker}</span>
            <div class="series-hd-text">
              <div class="series-hd-name">{s.name}</div>
              <div class="series-hd-tagline text-3">{s.tagline}</div>
            </div>
            <span class="mono text-3 series-count">{posts.length} post{posts.length !== 1 ? 's' : ''}</span>
          </div>
          <p class="series-desc text-2">{s.desc}</p>
          <div class="series-post-list">
            {posts.length === 0 ? (
              <div class="mono text-3 no-posts">// no posts yet</div>
            ) : posts.map((post, i) => (
              <a href={`/posts/${post.id}`} class="series-post-row">
                <span class="mono text-3 spr-num">{String(i+1).padStart(2,'0')}</span>
                <span class="spr-title">{post.data.title}</span>
                <div class="spr-tags">
                  {post.data.tags.map(tag => <span class="tag-chip mono">[{tag}]</span>)}
                </div>
                <span class="mono text-3 spr-date">
                  {post.data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
                </span>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</Base>
