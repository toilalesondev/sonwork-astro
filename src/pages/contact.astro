---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---
<Base title="Contact — Sơn Lê">
  <Nav active="contact" />

  <div class="contact-wrap">
    <div class="page-prompt mono text-3">./contact</div>
    <h1 class="contact-title">Say something worth saying.</h1>
    <p class="contact-sub">No pitches. No collab requests with decks attached. If you have something real to say, the bar is low.</p>

    <div class="contact-links">
      <a href="mailto:son@perfeat.org" class="contact-row">
        <span class="mono amber cr-marker">&gt;</span>
        <div class="cr-info">
          <div class="cr-label">son@perfeat.org</div>
          <div class="mono text-3 cr-sub">email</div>
        </div>
        <span class="mono text-3">↗</span>
      </a>
      <a href="https://x.com/toilaleson" target="_blank" rel="noopener" class="contact-row">
        <span class="mono amber cr-marker">&gt;</span>
        <div class="cr-info">
          <div class="cr-label">@toilaleson</div>
          <div class="mono text-3 cr-sub">x / twitter</div>
        </div>
        <span class="mono text-3">↗</span>
      </a>
      <a href="https://perfeat.org" target="_blank" rel="noopener" class="contact-row">
        <span class="mono amber cr-marker">&gt;</span>
        <div class="cr-info">
          <div class="cr-label">perfeat.org</div>
          <div class="mono text-3 cr-sub">what i'm building</div>
        </div>
        <span class="mono text-3">↗</span>
      </a>
    </div>

    <div class="mono text-3 contact-note">// I reply when there's something to reply to.</div>
  </div>
</Base>
