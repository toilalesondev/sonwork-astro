---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { projects } from '../data/projects';
---

<Base title="Projects — Sơn Lê">
  <Nav active="projects" />

  <div class="page-wrap">
    <h1 class="page-title">Projects</h1>
    <p class="page-sub">What I'm building, and where each one stands right now.</p>

    <div class="projects-list">
      {projects.map(p => (
        <div class="project-card no-link">
          <div class="project-hd">
            <span class="project-emoji">{p.emoji}</span>
            <div class="project-info">
              <div class="project-name">{p.name}</div>
              <div class="project-tagline text-3">{p.tagline}</div>
            </div>
            <span class:list={['project-status', `status-${p.status}`, 'mono']}>{p.status}</span>
          </div>
          <p class="project-desc">{p.description}</p>
          <div class="project-highlights">
            {p.highlights.map(h => (
              <span class="project-highlight">{h}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="projects-legend text-3">
      <span class="legend-dot active-dot"></span> active <span class="legend-dot building-dot"></span> building <span class="legend-dot parked-dot"></span> parked
    </div>
  </div>
</Base>
