---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base title="404 — Sơn Lê">
  <Nav active="" />

  <main class="page-wrap">
    <section class="notfound">
      <span class="notfound-code" aria-hidden="true">404</span>
      <h1 class="notfound-title">This page doesn't exist</h1>
      <p class="notfound-sub">
        The writing, project, or path you're looking for isn't here yet.
        Maybe it's still being figured out.
      </p>
      <p class="notfound-sub">
        <a href="/" class="notfound-link">Head back home →</a>
      </p>
    </section>

    <div class="journal-rules" aria-hidden="true"></div>
  </main>
</Base>

<style>
  .notfound { display:flex;flex-direction:column;align-items:center;text-align:center;padding:72px 0 24px; }
  .notfound-code { font-family:var(--serif);font-size:clamp(6rem,20vw,10rem);font-weight:800;color:var(--accent-bg);line-height:1;letter-spacing:-0.03em;user-select:none; }
  .notfound-title { font-family:var(--serif);font-size:clamp(1.75rem,4vw,2.25rem);font-weight:700;color:var(--text);margin-bottom:12px;text-wrap:balance; }
  .notfound-sub { font-size:1.0625rem;color:var(--text-2);line-height:1.7;margin-bottom:8px;max-width:44ch;text-wrap:pretty; }
  .notfound-link { color:var(--accent);font-weight:500;text-decoration:underline;text-underline-offset:.18em;text-decoration-thickness:1px;text-decoration-color:rgba(158,58,22,.4);transition:text-decoration-color .15s; }
  .notfound-link:hover { text-decoration-color:var(--accent); }
</style>
