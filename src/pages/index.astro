---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import { seriesMeta, seriesKeys } from '../data/series';

const allPosts = (await getCollection('posts', ({data}) => !data.draft))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const activeProjects = projects.filter(p => p.status === 'active' || p.status === 'building');

const seriesMap = seriesMeta;

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();
const seriesCounts = Object.fromEntries(
  seriesKeys.map(s => [s, allPosts.filter(p => p.data.series === s).length])
);
const totalReadTime = allPosts.reduce((acc, p) => acc + parseInt(p.data.readTime), 0);
---
<Base>
  <Nav active="dashboard" />

  <div class="dashboard-wrap">
    <main class="dash-main">

      <!-- HERO -->
      <section class="hero">
        <div class="hero-left">
          <div class="hero-prompt"><span class="mono text-3">./introduction</span></div>
          <div class="hero-avatar">SL</div>
          <h1 class="hero-name">Sơn Lê</h1>
          <div class="hero-hook">
            I've sat on both sides of the table. Neither was comfortable.<span class="cursor">▊</span>
          </div>
          <div class="hero-roles">
            <span class="role-item">VC</span>
            <span class="role-sep mono">→</span>
            <span class="role-item">Operator</span>
            <span class="role-sep mono">→</span>
            <span class="role-item active">Builder</span>
          </div>
          <div class="hero-company mono text-3">
            Co-founder, <a href="https://perfeat.org" target="_blank" rel="noopener" class="amber-link">Perfeat.org ↗</a>
          </div>
          <p class="hero-bio">
            Spent years writing checks, then years cashing out reputation. Now I build things in Saigon and write about what I notice.
          </p>
          <div class="hero-ctas">
            <a href="/projects" class="btn-primary">See projects</a>
            <a href="/series" class="btn-ghost">Read the writing</a>
            <a href="/about" class="btn-ghost">About me</a>
          </div>
        </div>
        <div class="hero-right">
          <div class="stats-card">
            <div class="stats-label mono">STATS</div>
            <div class="stat-row"><span class="mono text-3">posts_written</span><span class="mono amber">{allPosts.length}</span></div>
            <div class="stat-row"><span class="mono text-3">series</span><span class="mono amber">3</span></div>
            <div class="stat-row"><span class="mono text-3">years_logged</span><span class="mono amber">1</span></div>
            <div class="stat-row"><span class="mono text-3">est_read_time</span><span class="mono amber">{totalReadTime} min</span></div>
          </div>
        </div>
      </section>

      <!-- FEATURED PROJECTS -->
      <section class="fp-section">
        <div class="fp-hd">
          <span class="mono fp-hd-label">featured projects</span>
          <a href="/projects" class="mono fp-hd-all">view all →</a>
        </div>
        <div class="fp-cards">
          {activeProjects.map(p => (
            <a href={p.url || '/projects'} class:list={['fp-card', `fp-${p.slug}`]}>
              <div class="fp-card-accent"></div>
              <div class="fp-card-body">
                <div class="fp-card-top">
                  <span class="fp-card-emoji">{p.emoji}</span>
                  <span class:list={['mono', 'fp-card-badge', `fp-badge-${p.status}`]}>{p.status}</span>
                </div>
                <div class="fp-card-name">{p.name}</div>
                <div class="fp-card-tag">{p.tagline}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- TABS -->
      <div class="tab-strip" id="tabs">
        <button class="tab active" data-series="all">All</button>
        {Object.entries(seriesMap).map(([key, s]) => (
          <button class="tab" data-series={key}>
            <span class="mono">{s.marker}</span> {s.name}
          </button>
        ))}
      </div>

      <!-- ACTIVE TAG BAR -->
      <div id="activeTagBar" class="active-tag-bar" style="display:none">
        <span class="mono text-3">filtering:</span>
        <span class="mono amber" id="activeTagLabel"></span>
        <button class="clear-tag" id="clearTagBtn">× clear</button>
      </div>

      <!-- POST FEED -->
      <div class="post-feed" id="postFeed">
        {allPosts.map(post => {
          const s = seriesMap[post.data.series];
          return (
            <a href={`/posts/${post.id}`}
               class="post-row"
               data-series={post.data.series}
               data-tags={post.data.tags.join(',')}>
              <span class={`post-marker mono ${s.badgeClass}`}>{s.marker}</span>
              <div class="post-middle">
                <span class="post-title">{post.data.title}</span>
                <div class="post-tags">
                  {post.data.tags.map(tag => (
                    <button class="tag-chip mono" data-tag={tag}
                      onclick={`event.preventDefault();event.stopPropagation();filterTag('${tag}')`}>[{tag}]</button>
                  ))}
                </div>
              </div>
              <span class="post-date mono text-3">
                {post.data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
              </span>
            </a>
          );
        })}
      </div>

    </main>

    <!-- SIDEBAR -->
    <aside class="dash-sidebar">
      <div class="sidebar-block">
        <div class="sidebar-hd mono">SERIES</div>
        {Object.entries(seriesMap).map(([key, s]) => (
          <a href="/series" class="sb-series-row">
            <span class="mono amber">{s.marker}</span>
            <span class="sb-name">{s.name}</span>
            <span class="mono text-3">{seriesCounts[key]}</span>
          </a>
        ))}
      </div>
      <div class="sidebar-block">
        <div class="sidebar-hd mono">PROJECTS</div>
        {activeProjects.map(p => (
          <a href={p.url || '/projects'} class="sb-series-row">
            <span class="mono amber">{p.emoji}</span>
            <span class="sb-name">{p.name}</span>
            <span class:list={['mono', 'text-3', `sidebar-status-${p.status}`]}>{p.status}</span>
          </a>
        ))}
      </div>
      <div class="sidebar-block">
        <div class="sidebar-hd mono">TOPICS</div>
        <div class="tag-cloud">
          {allTags.map(tag => (
            <button class="tag-chip mono sidebar-tag" data-tag={tag}
              onclick={`filterTag('${tag}')`}>[{tag}]</button>
          ))}
        </div>
      </div>
      <div class="sidebar-about mono text-3">
        Sơn Lê — VC, then operator, now builder. Writing to stay honest.
      </div>
    </aside>
  </div>

  <script>
    // Window augmentation for the inline filter handlers (used by onclick attrs).
    declare global {
      interface Window {
        filterTag: (tag: string) => void;
        clearTag: () => void;
      }
    }

    // Tab filtering
    document.querySelectorAll<HTMLElement>('.tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const series = btn.dataset.series;
        clearTagSilent();
        document.querySelectorAll<HTMLElement>('.post-row').forEach(row => {
          row.style.display = (series === 'all' || row.dataset.series === series) ? 'flex' : 'none';
        });
      });
    });

    // Tag filtering
    let activeTag: string | null = null;
    window.filterTag = function(tag: string) {
      if (activeTag === tag) { window.clearTag(); return; }
      activeTag = tag;
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      document.querySelector('.tab[data-series="all"]')?.classList.add('active');
      document.querySelectorAll<HTMLElement>('.post-row').forEach(row => {
        const tags = (row.dataset.tags || '').split(',');
        row.style.display = tags.includes(tag) ? 'flex' : 'none';
      });
      document.querySelectorAll<HTMLElement>('.tag-chip').forEach(c => c.classList.toggle('active', c.dataset.tag === tag));
      const bar = document.getElementById('activeTagBar');
      if (bar) bar.style.display = 'flex';
      const label = document.getElementById('activeTagLabel');
      if (label) label.textContent = tag;
    };
    window.clearTag = function() {
      clearTagSilent();
      document.querySelectorAll<HTMLElement>('.post-row').forEach(r => r.style.display = 'flex');
    };
    function clearTagSilent() {
      activeTag = null;
      document.querySelectorAll('.tag-chip').forEach(c => c.classList.remove('active'));
      const bar = document.getElementById('activeTagBar');
      if (bar) bar.style.display = 'none';
    }
    document.getElementById('clearTagBtn')?.addEventListener('click', () => window.clearTag());
  </script>
</Base>
