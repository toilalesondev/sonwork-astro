---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import { seriesMeta } from '../data/series';

const allPosts = (await getCollection('posts', ({data}) => !data.draft))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const activeProjects = projects.filter(p => p.status === 'active' || p.status === 'building');

const seriesMap = seriesMeta;
const totalReadTime = allPosts.reduce((acc, p) => acc + parseInt(p.data.readTime), 0);
---
<Base>
  <Nav active="dashboard" />

  <main class="home">

    <!-- WHO -->
    <section class="hero">
      <div class="hero-prompt mono text-3">./introduction</div>
      <h1 class="hero-name">Sơn Lê</h1>
      <p class="hero-hook">
        I've sat on both sides of the table. Neither was comfortable.<span class="cursor">▊</span>
      </p>
      <div class="hero-roles">
        <span class="role-item">VC</span>
        <span class="role-sep mono">→</span>
        <span class="role-item">Operator</span>
        <span class="role-sep mono">→</span>
        <span class="role-item active">Builder</span>
        <span class="hero-company mono text-3">
          · Co-founder, <a href="https://perfeat.org" target="_blank" rel="noopener" class="accent-link">Perfeat.org ↗</a>
        </span>
      </div>
      <p class="hero-bio">
        Spent years writing checks, then years cashing out reputation. Now I build things in
        Saigon and write about what I notice.
      </p>
      <div class="hero-ctas">
        <a href="/series" class="btn-primary">Read the writing</a>
        <a href="/projects" class="btn-ghost">See projects</a>
      </div>
      <div class="hero-meta mono text-3">
        {allPosts.length} posts · 3 series · {totalReadTime} min of reading
      </div>
    </section>

    <!-- WHAT I'M BUILDING -->
    {activeProjects.length > 0 && (
      <section class="home-section">
        <div class="section-hd">
          <h2 class="section-title mono">Building</h2>
          <a href="/projects" class="section-all mono">all projects →</a>
        </div>
        <div class="fp-cards">
          {activeProjects.map(p => (
            <a href="/projects" class:list={['fp-card', `fp-${p.slug}`]}>
              <div class="fp-card-accent"></div>
              <div class="fp-card-body">
                <div class="fp-card-top">
                  <span class="fp-card-emoji">{p.emoji}</span>
                  <span class:list={['mono', 'fp-card-badge', `fp-badge-${p.status}`]}>{p.status}</span>
                </div>
                <div class="fp-card-name">{p.name}</div>
                <div class="fp-card-tag">{p.tagline}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- WRITING -->
    <section class="home-section">
      <div class="section-hd">
        <h2 class="section-title mono">Writing</h2>
        <a href="/series" class="section-all mono">by series →</a>
      </div>

      <div class="tab-strip" id="tabs">
        <button class="tab active" data-series="all">All</button>
        {Object.entries(seriesMap).map(([key, s]) => (
          <button class="tab" data-series={key}>
            <span class="mono">{s.marker}</span> {s.name}
          </button>
        ))}
      </div>

      <div class="post-feed" id="postFeed">
        {allPosts.map(post => {
          const s = seriesMap[post.data.series];
          return (
            <a href={`/posts/${post.id}`}
               class="post-row"
               data-series={post.data.series}>
              <span class={`post-marker mono ${s.badgeClass}`}>{s.marker}</span>
              <span class="post-title">{post.data.title}</span>
              <span class="post-date mono text-3">
                {post.data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
              </span>
            </a>
          );
        })}
      </div>
    </section>

  </main>

  <script>
    // Series tab filtering — the single, meaningful filter axis for the feed.
    document.querySelectorAll<HTMLElement>('.tab').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const series = btn.dataset.series;
        document.querySelectorAll<HTMLElement>('.post-row').forEach(row => {
          row.style.display = (series === 'all' || row.dataset.series === series) ? 'flex' : 'none';
        });
      });
    });
  </script>
</Base>
