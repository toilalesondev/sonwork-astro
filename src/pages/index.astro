---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';

const allPosts = (await getCollection('posts', ({data}) => !data.draft))
  .sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const activeProjects = projects.filter(p => p.status === 'active' || p.status === 'building');

const totalReadTime = allPosts.reduce((acc, p) => acc + parseInt(p.data.readTime), 0);
---
<Base>
  <Nav active="dashboard" />

  <main class="home">

    <!-- WHO -->
    <section class="hero">
      <h1 class="hero-name">Sơn Lê</h1>
      <p class="hero-hook">Still learning. Writing it down as I go.</p>
      <div class="hero-roles">
        <span class="role-item">VC</span>
        <span class="role-sep">→</span>
        <span class="role-item">Operator</span>
        <span class="role-sep">→</span>
        <span class="role-item active">Builder</span>
        <span class="hero-company">
          Founder of <a href="https://perfeat.org" target="_blank" rel="noopener" class="accent-link">Perfeat ↗</a>
        </span>
      </div>
      <p class="hero-bio">
        Spent years on the VC side, then the operator side. Now building in Saigon,
        and writing about what I'm figuring out along the way.
      </p>
      <div class="hero-ctas">
        <a href="/writing" class="btn-primary">Read the writing</a>
        <a href="/projects" class="btn-ghost">See projects</a>
      </div>
      <div class="hero-meta mono text-3">
        {allPosts.length === 0
          ? <span>Saigon · building &amp; writing</span>
          : <><span class="accent">{allPosts.length}</span> {allPosts.length === 1 ? 'post' : 'posts'} · <span class="accent">{totalReadTime}</span> min of reading</>}
      </div>
    </section>

    <!-- WHAT I'M BUILDING -->
    {activeProjects.length > 0 && (
      <section class="home-section">
        <div class="section-hd">
          <h2 class="section-title">Building</h2>
          <a href="/projects" class="section-all">all projects →</a>
        </div>
        <div class="fp-cards">
          {activeProjects.map(p => (
            <a href="/projects" class:list={['fp-card', `fp-${p.slug}`]}>
              <div class="fp-card-accent"></div>
              <div class="fp-card-body">
                <div class="fp-card-top">
                  <span class="fp-card-emoji">{p.emoji}</span>
                  <span class:list={['mono', 'fp-card-badge', `fp-badge-${p.status}`]}>{p.status}</span>
                </div>
                <div class="fp-card-name">{p.name}</div>
                <div class="fp-card-tag">{p.tagline}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- WRITING -->
    <section class="home-section">
      <div class="section-hd">
        <h2 class="section-title">Writing</h2>
        {allPosts.length > 0 && <a href="/writing" class="section-all">all →</a>}
      </div>

      {allPosts.length === 0 ? (
        <div class="writing-empty">
          <p class="writing-empty-lead">Nothing published yet.</p>
          <p class="writing-empty-sub">
            I'm writing as I build. The first pieces go up here soon. Notes on
            shipping in Saigon, on what a year of building actually teaches you,
            on the people I keep learning from.
          </p>
        </div>
      ) : (
        <div class="post-feed">
          {allPosts.map(post => (
            <a href={`/posts/${post.id}`} class="post-row">
              <span class="post-title">{post.data.title}</span>
              <span class="post-date mono text-3">
                {post.data.pubDate.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
              </span>
            </a>
          ))}
        </div>
      )}
    </section>

  </main>
</Base>
